# LINE API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Twilio API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+81xxxxxxxxxx

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_JSON={"type": "service_account", ...}
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# 管制LINE ID
CONTROL_LINE_ID=your_control_line_id

# オプション: 髙木LINE ID（Procastデータ未取得通知用）
TAKAGI_LINE_ID=your_takagi_line_id

# オプション: Slack Webhook（エラー通知用）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# オプション: Google Drive API（Procastデータ取得用）
GOOGLE_DRIVE_CREDENTIALS_JSON={"type": "service_account", ...}
GOOGLE_DRIVE_PROCAST_FOLDER_ID=your_folder_id
GOOGLE_DRIVE_PROCAST_FILE_NAME=procast_data.csv

# タイムゾーン
TZ=Asia/Tokyo

# ログ設定
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# API設定
API_HOST=0.0.0.0
API_PORT=8000
